// CIMantic Graphs + CIMTool + GLIMPSE hands-on demo.
// For format details, see https://aka.ms/devcontainer.json.
{
	"name": "CIM Tools Demo (cimgraph + CIMTool + GLIMPSE)",
	// Built from ./Dockerfile, which pins the Ubuntu 24.04 base (glibc 2.39) that
	// GLIMPSE's bundled Python server requires; see the Dockerfile for details.
	"build": {
		"dockerfile": "Dockerfile"
	},
	"hostRequirements": {
		"cpus": 4
	},
	// desktop-lite = a lightweight fluxbox desktop reachable in the browser over
	// noVNC (port 6080). It hosts the two GUI apps: CIMTool (Eclipse RCP) and
	// GLIMPSE (Electron). java is a system JRE for the headless cimtool-cli.jar
	// (CIMTool's GUI product ships its own bundled JRE). uv drives the Python env.
	"features": {
		// The Ubuntu base has no Python; this feature provides it and uv builds
		// the project venv on top. cim-graph supports 3.10–3.13.
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.12"
		},
		"ghcr.io/devcontainers/features/desktop-lite:1": {
			"password": "cimtool",
			"webPort": "6080",
			"vncPort": "5901"
		},
		// JDK 21 (LTS) for the headless cimtool-cli.jar. SDKMAN no longer offers
		// the non-LTS JDK 20; the CIMTool GUI ships its own bundled JRE anyway.
		"ghcr.io/devcontainers/features/java:1": {
			"version": "21",
			"installGradle": "false",
			"installMaven": "false"
		},
		"ghcr.io/va-h/devcontainers-features/uv:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"github.vscode-pull-request-github",
				"eamodio.gitlens",
				"ms-toolsai.jupyter"
			],
			"settings": {
				"python.testing.pytestEnabled": true,
				"python.testing.unittestEnabled": false,
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
			}
		}
	},
	// 6080 is the noVNC desktop; open it in a browser to reach CIMTool and GLIMPSE.
	"forwardPorts": [6080],
	"portsAttributes": {
		"6080": {
			"label": "CIMTool + GLIMPSE Desktop (noVNC)",
			"onAutoForward": "openBrowser"
		}
	},
	"postCreateCommand": "bash scripts/setup.sh"
}
